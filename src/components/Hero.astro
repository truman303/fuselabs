---
/**
 * Hero with a "pixel fusion" SVG mark — a carbon copy of the FuseLab
 * logo in its resting state: two stacked rounded-rect windows (for depth)
 * with a sparse pixel cluster bursting out of the front window's upper-left.
 *
 * Each pixel position is hand-placed (not procedurally generated) so the
 * composition matches the brand mark exactly. The client script animates
 * pixels in from scattered positions and draws the frames last.
 */

type Pixel = { col: number; row: number; accent: boolean };

// Hand-placed pixels — a sparse, irregular scatter (deliberately NOT a
// diamond or circle) that originates at the front frame's top-left
// corner and fans out across the whole screen, thinning as it spreads.
// Cyan accents are interleaved so the flow still reads as motion.
// Grid coords span ~12 cols x 9 rows; most cells are intentionally
// empty so the mark never feels like a solid grid of dots.
const PIXELS: Pixel[] = [
  // Row 0 — single isolated outlier (the "escaped" pixel)
  { col: 2, row: 0, accent: true },

  // Row 1 — thin broken trail
  { col: 0, row: 1, accent: false },
  { col: 3, row: 1, accent: false },
  { col: 4, row: 1, accent: true },

  // Row 2 — gappy upper band
  { col: 1, row: 2, accent: false },
  { col: 2, row: 2, accent: true },
  { col: 5, row: 2, accent: false },
  { col: 8, row: 2, accent: false },

  // Row 3 — densest strip, hugging the front frame's top edge
  { col: 0, row: 3, accent: false },
  { col: 1, row: 3, accent: true },
  { col: 3, row: 3, accent: false },
  { col: 4, row: 3, accent: false },
  { col: 7, row: 3, accent: true },

  // Row 4 — offset trail drifting right across the frame
  { col: 2, row: 4, accent: false },
  { col: 4, row: 4, accent: true },
  { col: 6, row: 4, accent: false },
  { col: 9, row: 4, accent: false },

  // Row 5 — mid-frame scatter
  { col: 1, row: 5, accent: false },
  { col: 3, row: 5, accent: false },
  { col: 7, row: 5, accent: true },
  { col: 10, row: 5, accent: false },

  // Row 6 — thinning as it fans out
  { col: 2, row: 6, accent: false },
  { col: 5, row: 6, accent: true },
  { col: 8, row: 6, accent: false },
  { col: 11, row: 6, accent: false },

  // Row 7 — sparse lower band
  { col: 4, row: 7, accent: false },
  { col: 9, row: 7, accent: true },

  // Row 8 — final echo near the bottom-right
  { col: 7, row: 8, accent: false },
  { col: 11, row: 8, accent: true },
];

const CELL = 22;
const GAP = 3;
const SIZE = CELL - GAP;

// Frames in grid coords. The front frame starts at (col 3, row 3) so the
// pixel cluster's upper-left corner breaks out of its top-left. The back
// frame is offset +1 col / -1 row to create the depth / stack illusion.
const FRONT = { col: 3, row: 3, w: 14, h: 10 };
const BACK = { col: 4, row: 2, w: 14, h: 10 };

const frontX = FRONT.col * CELL;
const frontY = FRONT.row * CELL;
const frontW = FRONT.w * CELL - GAP;
const frontH = FRONT.h * CELL - GAP;

const backX = BACK.col * CELL;
const backY = BACK.row * CELL;
const backW = BACK.w * CELL - GAP;
const backH = BACK.h * CELL - GAP;

const frontPerimeter = 2 * (frontW + frontH);
const backPerimeter = 2 * (backW + backH);

// Composition extents (covers both frames and the pixel burst)
const contentW = (BACK.col + BACK.w) * CELL;
const contentH = (FRONT.row + FRONT.h) * CELL;

// Padding around the viewBox so scatter-in pixels remain visible while
// they animate toward their resting positions.
const PAD = 120;
const vbX = -PAD;
const vbY = -PAD;
const vbW = contentW + PAD * 2;
const vbH = contentH + PAD * 2;

// Pixel cluster offset — shift the cluster toward the front frame's
// top-left corner so it reads as "bursting out" rather than floating
// off on its own. +1 col, +1 row keeps a handful of outlier pixels
// outside the frame while anchoring the bulk of the cluster to it.
const PIXEL_SHIFT_X = CELL;
const PIXEL_SHIFT_Y = CELL;

// Peeled-corner handle detail on the front window (appears in the logo).
const frontNotchX = frontX + 4;
const frontNotchY = frontY + frontH - 18;

const viewBoxAttr = `${vbX} ${vbY} ${vbW} ${vbH}`;
---

<section class="hero" id="top">
  <div class="wrap hero__wrap">
    <div class="hero__textual">
      <p class="eyebrow hero__eyebrow">FuseLab Digital · est. 2026</p>

      <h1 class="hero__title display">
        <span class="hero__line" data-line="1">
          <span class="hero__chars" aria-label="Where ideas">Where ideas</span>
        </span>
        <span class="hero__line" data-line="2">
          <span class="hero__chars hero__chars--italic display-italic" aria-label="fuse">fuse</span>
          <span class="hero__chars" aria-label="with">&nbsp;with</span>
        </span>
        <span class="hero__line" data-line="3">
          <span class="hero__chars" aria-label="engineering.">engineering.</span>
        </span>
      </h1>

      <p class="hero__lede lede">
        A boutique digital consultancy helping businesses harness technology to
        unlock new opportunities.
      </p>

      <div class="hero__actions">
        <a class="btn btn--primary" href="#contact">
          <span>Start a conversation</span>
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 14 14">
            <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="square"></path>
          </svg>
        </a>
        <a class="btn btn--ghost" href="#manifesto">
          Our approach
        </a>
      </div>
    </div>

    <div class="hero__mark" aria-hidden="true">
      {/*
        The mark is composed of three real depth planes stacked in 3D:
          1. Back frame  — furthest from the viewer
          2. Front frame — mid plane, the "screen"
          3. Pixel cluster — nearest, floating just above the front frame
        A gentle rotateY/rotateX on the scene container gives the whole
        composition the feel of a display tilted slightly off-axis.
      */}
      <div class="pixel-scene">
        <div class="pixel-scene-inner">
          {/* Plane 1 — back frame (cyan, recedes behind the front frame) */}
          <svg
            class="pixel-svg pixel-plane pixel-plane--back"
            viewBox={viewBoxAttr}
            role="presentation"
            aria-hidden="true"
          >
            <g class="pixel-frame-group pixel-frame-group--back">
              <rect
                class="pixel-frame pixel-frame--back"
                x={backX}
                y={backY}
                width={backW}
                height={backH}
                rx="6"
                ry="6"
                fill="none"
                stroke="var(--fuse-cyan)"
                stroke-width="2"
                stroke-linejoin="round"
                stroke-dasharray={backPerimeter}
                stroke-dashoffset={backPerimeter}
              />
            </g>
          </svg>

          {/* Plane 2 — front frame */}
          <svg
            class="pixel-svg pixel-plane pixel-plane--front"
            viewBox={viewBoxAttr}
            role="presentation"
            aria-hidden="true"
          >
            <g class="pixel-frame-group pixel-frame-group--front">
              <rect
                class="pixel-frame pixel-frame--front"
                x={frontX}
                y={frontY}
                width={frontW}
                height={frontH}
                rx="6"
                ry="6"
                fill="none"
                stroke="var(--bone)"
                stroke-width="2.5"
                stroke-linejoin="round"
                stroke-dasharray={frontPerimeter}
                stroke-dashoffset={frontPerimeter}
              />
              <path
                class="pixel-frame-notch"
                d={`M ${frontNotchX} ${frontNotchY} l 0 14`}
                stroke="var(--bone)"
                stroke-width="2.5"
                stroke-linecap="round"
                fill="none"
              />
            </g>
          </svg>

          {/* Plane 3 — pixel cluster, nearest to the viewer */}
          <svg
            class="pixel-svg pixel-plane pixel-plane--pixels"
            viewBox={viewBoxAttr}
            role="presentation"
            aria-hidden="true"
          >
            <defs>
              <filter id="pixelGlow" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="1.6" result="blur" />
                <feMerge>
                  <feMergeNode in="blur" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
            </defs>

            <g
              class="pixel-cluster"
              transform={`translate(${PIXEL_SHIFT_X} ${PIXEL_SHIFT_Y})`}
            >
              {
                PIXELS.map((p, i) => (
                  <rect
                    class={`pixel${p.accent ? ' pixel--accent' : ''}`}
                    data-i={i}
                    data-accent={p.accent ? 'true' : 'false'}
                    data-row={p.row}
                    x={p.col * CELL}
                    y={p.row * CELL}
                    width={SIZE}
                    height={SIZE}
                    rx="1.5"
                    ry="1.5"
                    fill={p.accent ? 'var(--fuse-cyan)' : 'var(--bone)'}
                  />
                ))
              }
            </g>
          </svg>
        </div>
      </div>
      <div class="hero__mark-caption mono">
        <span>// pixel_fusion.svg</span>
        <span>
          {PIXELS.length} cells ·{' '}
          {Math.round(
            (PIXELS.filter((p) => p.accent).length / PIXELS.length) * 100,
          )}% accent
        </span>
      </div>
    </div>
  </div>

  <div class="hero__scroll mono" aria-hidden="true">
    <span>Scroll</span>
    <span class="hero__scroll-line"></span>
  </div>
</section>

<script>
  import { initPixelFusion } from '../scripts/pixelFusion';
  initPixelFusion();
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    padding-block: clamp(6rem, 12vh, 9rem) var(--section-y);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--hairline) 1px, transparent 1px),
      linear-gradient(to bottom, var(--hairline) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 60% 50% at 50% 40%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 40%, black 30%, transparent 80%);
    opacity: 0.35;
    pointer-events: none;
  }

  .hero__wrap {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(2rem, 6vw, 6rem);
    align-items: center;
    position: relative;
  }

  .hero__eyebrow {
    margin: 0 0 var(--s-6) 0;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero__eyebrow::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--fuse-cyan);
    box-shadow: 0 0 16px var(--fuse-cyan);
  }

  .hero__title {
    font-size: var(--step-5);
    margin: 0 0 var(--s-6) 0;
    font-weight: 300;
  }

  .hero__line {
    display: block;
    /* overflow: hidden masks the yPercent:110 line-reveal animation on
       .hero__chars, but the default content-box stops at the baseline,
       which clips descenders (e.g. the "g" tails in "engineering").
       Extend the mask downward with padding-bottom, then pull the next
       line back up with an equal negative margin so the visual rhythm
       between lines — and the gap down to .hero__lede — is unchanged. */
    overflow: hidden;
    padding-bottom: 0.22em;
    margin-bottom: -0.22em;
  }

  .hero__chars {
    display: inline-block;
    will-change: transform;
  }

  .hero__chars--italic {
    color: var(--fuse-cyan);
    padding-right: 0.12em;
  }

  .hero__lede {
    margin: 0 0 var(--s-6) 0;
    max-width: 34ch;
    opacity: 0;
    color: var(--bone-dim);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    opacity: 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    padding: 0.95em 1.5em;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    border: 1px solid transparent;
    transition:
      background 240ms var(--ease-out-expo),
      color 240ms var(--ease-out-expo),
      border-color 240ms var(--ease-out-expo),
      transform 240ms var(--ease-out-expo);
  }

  .btn--primary {
    background: var(--fuse-cyan);
    color: var(--ink);
    border-color: var(--fuse-cyan);
  }

  .btn--primary:hover {
    background: transparent;
    color: var(--fuse-cyan);
    transform: translateY(-2px);
  }

  .btn--ghost {
    background: transparent;
    color: var(--bone);
    border-color: var(--hairline);
  }

  .btn--ghost:hover {
    border-color: var(--bone);
    transform: translateY(-2px);
  }

  .hero__mark {
    position: relative;
    display: grid;
    justify-items: end;
    gap: var(--s-4);
    filter: drop-shadow(0 24px 60px rgba(0, 174, 239, 0.14));
  }

  .hero__mark svg {
    overflow: visible;
  }

  /* -- 3D scene ------------------------------------------------------
     Three real depth planes stacked with CSS 3D. The outer .pixel-scene
     establishes the perspective; .pixel-scene-inner rotates the whole
     stack so the "screen" faces slightly off-axis; each .pixel-plane
     is parked at its own z-depth (back < front < pixels).
  ------------------------------------------------------------------- */
  .pixel-scene {
    position: relative;
    width: 100%;
    max-width: 560px;
    aspect-ratio: 636 / 526; /* matches the shared viewBox */
    perspective: 1600px;
    perspective-origin: 58% 42%;
    opacity: 0;
    will-change: opacity, filter, transform;
    filter: blur(14px) brightness(0.55) saturate(0.6);
  }

  .pixel-scene-inner {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    /* Base tilt lives here so the scene has its slant even before JS
       runs; GSAP composes mouse parallax on top of these values. */
    transform: rotateX(7deg) rotateY(-12deg) rotateZ(-1deg);
    transform-origin: 58% 48%;
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .pixel-scene-inner {
      transform: rotateX(4deg) rotateY(-8deg);
    }
  }

  .pixel-plane {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* Depth: back frame recedes, front frame is the anchor, pixels float
     out toward the viewer. Keeps the deltas subtle so the silhouette
     still reads as the FuseLab mark. */
  .pixel-plane--back {
    transform: translateZ(-58px);
  }

  .pixel-plane--front {
    transform: translateZ(0);
  }

  .pixel-plane--pixels {
    transform: translateZ(44px);
    /* A soft shadow cast "down" onto the front frame sells the lift. */
    filter: drop-shadow(2px 6px 6px rgba(0, 0, 0, 0.55));
  }

  /* Legacy selector kept for animation code that still references it;
     the scene-level filter/opacity is what actually drives the tune-in. */
  .pixel-svg {
    width: 100%;
    height: 100%;
  }

  .pixel-frame--back {
    opacity: 0.75;
  }

  .pixel-frame-notch {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
  }

  .pixel {
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    will-change: transform, opacity;
  }

  .pixel--accent {
    filter: url(#pixelGlow);
  }

  .hero__mark-caption {
    display: flex;
    justify-content: space-between;
    width: 100%;
    max-width: 560px;
    font-size: 0.7rem;
    opacity: 0;
    color: var(--smoke);
  }

  .hero__scroll {
    position: absolute;
    bottom: var(--s-6);
    left: var(--gutter);
    display: flex;
    align-items: center;
    gap: var(--s-3);
    font-size: 0.7rem;
    opacity: 0;
    color: var(--smoke);
  }

  .hero__scroll-line {
    display: inline-block;
    width: 3rem;
    height: 1px;
    background: linear-gradient(to right, var(--smoke), transparent);
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-line::after {
    content: '';
    position: absolute;
    inset: 0;
    width: 30%;
    background: var(--fuse-cyan);
    animation: scroll-pulse 2.4s var(--ease-in-out-expo) infinite;
  }

  @keyframes scroll-pulse {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(400%); }
  }

  /* Skip the "tune-in" choreography entirely for reduced-motion users
     and on mobile viewports (where the hero stacks and the 3D scene
     shrinks to an editorial masthead). The JS timeline in
     pixelFusion.ts uses the matching matchMedia query so the JS and
     CSS agree on when the final resting state should be rendered. */
  @media (prefers-reduced-motion: reduce), (max-width: 1000px) {
    .hero__chars { transform: none; }
    .hero__lede,
    .hero__actions,
    .hero__mark-caption,
    .hero__scroll { opacity: 1; }
    .pixel { opacity: 1; }
    .pixel-frame { stroke-dashoffset: 0 !important; }
    .pixel-frame-notch { opacity: 1; }
    .pixel-scene { opacity: 1; filter: none; }
    .hero__scroll-line::after { animation: none; }
  }

  /* ----------------------------------------------------------------
     Mobile / narrow-tablet treatment.

     The pixel-fusion mark is a desktop-scale moment — it depends on
     the two-column layout, a pointer for parallax, and enough room
     for the 3D scene to read. On small viewports we drop the mark
     (and the floor scroll indicator) entirely and let typography
     lead, keeping the hero close to one screen tall.

     The matching matchMedia query in pixelFusion.ts gates the intro
     timeline on the same breakpoint, so no animation work runs for
     these hidden nodes.
  ---------------------------------------------------------------- */
  @media (max-width: 1000px) {
    .hero {
      min-height: auto;
      padding-block: clamp(5rem, 10vh, 7rem) var(--s-7);
    }

    .hero__wrap {
      grid-template-columns: 1fr;
      gap: var(--s-5);
    }

    .hero__mark,
    .hero__scroll {
      display: none;
    }
  }
</style>
