---
const year = new Date().getFullYear();
---

<section class="section contact" id="contact">
  <div class="wrap">
    <header class="section-header">
      <span class="mono">05 / Contact</span>
      <span class="eyebrow">Work with us</span>
    </header>

    <div class="contact__grid">
      <h2 class="contact__title display reveal">
        Ambitious idea?
        <br />
        <span class="display-italic contact__accent">Let's talk.</span>
      </h2>

      <div class="contact__actions reveal">
        <a class="contact__mailto" href="mailto:hello@fuselab.digital">
          <span class="contact__mailto-label mono">Email</span>
          <span class="contact__mailto-value">hello@fuselab.digital</span>
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16">
            <path d="M1 8h14M9 2l6 6-6 6" stroke="currentColor" stroke-width="1.5" fill="none" />
          </svg>
        </a>

        <p class="contact__note">
          We reply to every message — usually within a working day. If we are a
          good fit for each other we will happily jump on a call.
        </p>
      </div>
    </div>
  </div>

  <footer class="footer">
    <div class="wrap footer__wrap">
      <p class="mono footer__copy">
        © {year} FuseLab Digital. All rights reserved.
      </p>
      <p class="mono footer__tag">
        <span class="footer__dot"></span>
        Built with craft in Cape Town
      </p>
      <a href="#top" class="mono footer__top">
        Back to top ↑
      </a>
    </div>
  </footer>
</section>

<style>
  .contact {
    padding-bottom: 0;
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--s-7);
    align-items: center;
    padding-block: var(--s-6) var(--s-9);
  }

  @media (max-width: 820px) {
    .contact__grid {
      grid-template-columns: 1fr;
      gap: var(--s-6);
    }
  }

  .contact__title {
    font-size: var(--step-6);
    font-weight: 300;
    margin: 0;
    line-height: 0.95;
    letter-spacing: -0.02em;
  }

  .contact__accent {
    color: var(--fuse-cyan);
  }

  .contact__actions {
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
  }

  .contact__mailto {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--s-3);
    align-items: center;
    padding: var(--s-5);
    border: 1px solid var(--hairline);
    background: var(--ink-2);
    transition:
      border-color 300ms var(--ease-out-expo),
      transform 300ms var(--ease-out-expo);
  }

  .contact__mailto:hover {
    border-color: var(--fuse-cyan);
    transform: translateY(-2px);
  }

  .contact__mailto:hover svg {
    transform: translateX(4px);
    color: var(--fuse-cyan);
  }

  .contact__mailto svg {
    transition: transform 300ms var(--ease-out-expo), color 300ms var(--ease-out-expo);
    color: var(--smoke);
  }

  .contact__mailto-label {
    color: var(--smoke);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .contact__mailto-value {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-2);
    color: var(--bone);
    letter-spacing: -0.01em;
  }

  .contact__note {
    margin: 0;
    color: var(--bone-dim);
    font-size: var(--step-0);
    max-width: 40ch;
  }

  .footer {
    border-top: 1px solid var(--hairline);
    padding-block: var(--s-5);
  }

  .footer__wrap {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--s-4);
    font-size: 0.7rem;
    color: var(--smoke);
  }

  .footer__copy,
  .footer__tag,
  .footer__top {
    margin: 0;
  }

  .footer__dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--fuse-cyan);
    box-shadow: 0 0 10px var(--fuse-cyan);
    margin-right: 0.5rem;
    vertical-align: middle;
    animation: footer-pulse 2.2s ease-in-out infinite;
  }

  @keyframes footer-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer__dot { animation: none; }
  }

  .footer__top:hover {
    color: var(--bone);
  }
</style>
