---
const founders = [
  {
    name: 'Deon Heunis',
    role: 'Technology Strategist',
    bio: 'Deon is a technology strategist with deep expertise in scalable architectures and digital transformation. He brings the systems thinking that lets ambitious products hold up over time.',
    initials: 'DH',
  },
  {
    name: 'Leo Redelignhuys',
    role: 'Product & Business Innovation',
    bio: 'Leo specialises in digital product strategy and business innovation, bridging the gap between vision and execution. She is the person who translates a business aim into a product people actually use.',
    initials: 'LR',
  },
];

const credits = [
  { label: 'Founded', value: 'Swipe iX' },
  { label: 'Founded', value: 'WeChatBuilder' },
  { label: 'Acquired by', value: 'Media24' },
  { label: 'Acquired by', value: 'MultiChoice' },
];
---

<section class="section founders" id="founders">
  <div class="wrap">
    <header class="section-header">
      <span class="mono">03 / Founders</span>
      <span class="eyebrow">Who is behind the work</span>
    </header>

    <p class="founders__intro lede reveal">
      FuseLab Digital was founded by
      <span class="founders__name">Deon Heunis</span> and
      <span class="founders__name">Leo Redelignhuys</span> — operators who have
      built and scaled digital ventures before, and know what it takes to turn
      ideas into real impact.
    </p>

    <div class="founders__grid">
      {
        founders.map((f) => (
          <article class="founder reveal">
            <div class="founder__avatar" aria-hidden="true">
              <span>{f.initials}</span>
              <svg class="founder__orbit" viewBox="0 0 120 120" aria-hidden="true">
                <circle cx="60" cy="60" r="58" fill="none" stroke="var(--hairline)" stroke-width="1" />
                <circle cx="60" cy="60" r="58" fill="none" stroke="var(--fuse-cyan)" stroke-width="1" stroke-dasharray="6 360" class="founder__tick" />
              </svg>
            </div>
            <div class="founder__meta">
              <h3 class="founder__name">{f.name}</h3>
              <p class="founder__role mono">{f.role}</p>
              <p class="founder__bio">{f.bio}</p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="founders__track-record reveal" aria-label="Previous ventures">
      <span class="mono founders__tr-label">Track record</span>
      <ul class="founders__credits">
        {
          credits.map((c) => (
            <li>
              <span class="mono founders__credit-label">{c.label}</span>
              <span class="founders__credit-value">{c.value}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .founders__intro {
    max-width: 48ch;
    margin: 0 0 var(--s-8) 0;
  }

  .founders__name {
    color: var(--bone);
    border-bottom: 1px solid var(--fuse-cyan);
    padding-bottom: 0.1em;
  }

  .founders__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-7);
    margin-bottom: var(--s-8);
  }

  @media (max-width: 760px) {
    .founders__grid {
      grid-template-columns: 1fr;
    }
  }

  .founder {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: var(--s-5);
    padding: var(--s-5);
    border: 1px solid var(--hairline);
    background:
      linear-gradient(135deg, rgba(0, 174, 239, 0.03) 0%, transparent 60%),
      var(--ink-2);
    position: relative;
    transition:
      border-color 400ms var(--ease-out-expo),
      transform 400ms var(--ease-out-expo);
  }

  .founder:hover {
    border-color: var(--fuse-cyan-dim);
    transform: translateY(-3px);
  }

  .founder:hover .founder__tick {
    animation-play-state: running;
  }

  .founder__avatar {
    position: relative;
    width: 7rem;
    height: 7rem;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: var(--step-3);
    color: var(--bone);
    background:
      radial-gradient(circle at 30% 30%, rgba(0, 174, 239, 0.18), transparent 60%),
      var(--ink);
    border: 1px solid var(--hairline);
    border-radius: 50%;
  }

  .founder__orbit {
    position: absolute;
    inset: -6px;
    width: calc(100% + 12px);
    height: calc(100% + 12px);
  }

  .founder__tick {
    transform-origin: 50% 50%;
    animation: orbit-rotate 8s linear infinite;
    animation-play-state: paused;
  }

  @keyframes orbit-rotate {
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .founder__tick { animation: none; }
  }

  .founder__meta {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }

  .founder__name {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: var(--step-2);
    letter-spacing: -0.015em;
    margin: 0;
    line-height: 1;
  }

  .founder__role {
    color: var(--fuse-cyan);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0;
  }

  .founder__bio {
    margin: var(--s-3) 0 0 0;
    color: var(--bone-dim);
    font-size: var(--step-0);
    line-height: 1.55;
  }

  @media (max-width: 520px) {
    .founder {
      grid-template-columns: 1fr;
    }
    .founder__avatar {
      margin-inline: auto;
    }
  }

  .founders__track-record {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: var(--s-5);
    padding-top: var(--s-6);
    border-top: 1px solid var(--hairline);
    align-items: start;
  }

  .founders__tr-label {
    color: var(--smoke);
  }

  .founders__credits {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-5);
  }

  .founders__credits li {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: var(--s-3) 0;
    border-top: 1px solid var(--hairline);
  }

  .founders__credit-label {
    font-size: 0.7rem;
    color: var(--smoke);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .founders__credit-value {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-1);
    color: var(--bone);
  }

  @media (max-width: 760px) {
    .founders__track-record {
      grid-template-columns: 1fr;
    }
    .founders__credits {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
