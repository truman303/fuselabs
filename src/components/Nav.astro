---
// Minimal top nav. Becomes slightly more opaque on scroll (JS toggles class).
---

<nav class="nav" aria-label="Primary">
  <div class="wrap nav__wrap">
    <a href="#top" class="nav__brand" aria-label="FuseLab Digital">
      {/*
        Static, pocket-sized twin of the Hero's pixel-fusion mark:
        two stacked rounded-rect "windows" (back = cyan, recedes;
        front = bone, anchor) with a sparse pixel burst escaping the
        front window's top-left corner. Intentionally tiny and
        unanimated so it reads cleanly at nav scale.
      */}
      <svg
        class="nav__mark"
        viewBox="0 0 32 32"
        width="28"
        height="28"
        role="presentation"
        aria-hidden="true"
      >
        <rect
          class="nav__mark-frame nav__mark-frame--back"
          x="11"
          y="7.5"
          width="17"
          height="13"
          rx="2"
          ry="2"
          fill="none"
          stroke="var(--fuse-cyan)"
          stroke-width="1"
          stroke-linejoin="round"
        />
        <rect
          class="nav__mark-frame nav__mark-frame--front"
          x="7"
          y="11"
          width="17"
          height="13"
          rx="2"
          ry="2"
          fill="none"
          stroke="var(--bone)"
          stroke-width="1.4"
          stroke-linejoin="round"
        />
        <g class="nav__mark-pixels">
          {/* Outliers — the scatter that breaks out past the frames */}
          <rect x="1.8" y="1.8" width="2.2" height="2.2" rx="0.4" fill="var(--fuse-cyan)" />
          <rect x="5.4" y="3.8" width="2.2" height="2.2" rx="0.4" fill="var(--bone)" />
          <rect x="2.8" y="6" width="2.2" height="2.2" rx="0.4" fill="var(--bone)" />
          <rect x="7" y="6.8" width="2.2" height="2.2" rx="0.4" fill="var(--fuse-cyan)" />
          <rect x="0.4" y="9" width="2.2" height="2.2" rx="0.4" fill="var(--bone)" />
          {/* Near-frame / overlay pixels — hug and cross the front window's
              top-left, giving the burst the same density as the hero mark. */}
          <rect x="4.2" y="9.2" width="2.2" height="2.2" rx="0.4" fill="var(--bone)" />
          <rect x="9" y="9.2" width="2.2" height="2.2" rx="0.4" fill="var(--fuse-cyan)" />
          <rect x="14.6" y="9.6" width="2.2" height="2.2" rx="0.4" fill="var(--bone)" />
          <rect x="5.8" y="12.8" width="2.2" height="2.2" rx="0.4" fill="var(--bone)" />
          <rect x="10.6" y="12.6" width="2.2" height="2.2" rx="0.4" fill="var(--fuse-cyan)" />
        </g>
      </svg>
      <span class="nav__wordmark">
        FuseLab<span class="nav__wordmark-dim">&nbsp;Digital</span>
      </span>
    </a>

    <ul class="nav__links">
      <li><a href="#manifesto">Manifesto</a></li>
      <li><a href="#approach">Approach</a></li>
      <li><a href="#founders">Founders</a></li>
      <li><a href="#partnership">Partnership</a></li>
    </ul>

    <a href="#contact" class="nav__cta">
      <span>Get in touch</span>
    </a>
  </div>
</nav>

<script>
  const nav = document.querySelector<HTMLElement>('.nav');
  if (nav) {
    const onScroll = () => {
      nav.classList.toggle('nav--scrolled', window.scrollY > 40);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding-block: var(--s-4);
    transition:
      padding-block 300ms var(--ease-out-expo),
      background 300ms var(--ease-out-expo),
      border-color 300ms var(--ease-out-expo),
      backdrop-filter 300ms var(--ease-out-expo);
    border-bottom: 1px solid transparent;
  }

  .nav--scrolled {
    padding-block: var(--s-3);
    background: color-mix(in srgb, var(--ink) 75%, transparent);
    backdrop-filter: blur(12px) saturate(1.4);
    -webkit-backdrop-filter: blur(12px) saturate(1.4);
    border-bottom-color: var(--hairline);
  }

  .nav__wrap {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--s-5);
    align-items: center;
  }

  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    color: var(--bone);
  }

  .nav__mark {
    width: 28px;
    height: 28px;
    overflow: visible;
    filter: drop-shadow(0 0 0 transparent);
    transition:
      filter 300ms var(--ease-out-expo),
      transform 400ms var(--ease-out-expo);
  }

  .nav__mark-frame--back {
    opacity: 0.7;
  }

  .nav__brand:hover .nav__mark {
    filter: drop-shadow(0 0 8px rgba(0, 174, 239, 0.55));
    transform: translateY(-1px);
  }

  .nav__wordmark-dim {
    color: var(--smoke);
  }

  .nav__links {
    display: flex;
    gap: var(--s-5);
    justify-content: center;
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .nav__links a {
    color: var(--smoke);
    position: relative;
    padding-block: 0.25rem;
    transition: color 200ms var(--ease-out-expo);
  }

  .nav__links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 0;
    height: 1px;
    background: var(--fuse-cyan);
    transition: width 300ms var(--ease-out-expo);
  }

  .nav__links a:hover {
    color: var(--bone);
  }

  .nav__links a:hover::after {
    width: 100%;
  }

  .nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.1rem;
    border: 1px solid var(--hairline);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--bone);
    transition:
      border-color 240ms var(--ease-out-expo),
      color 240ms var(--ease-out-expo),
      background 240ms var(--ease-out-expo);
  }

  .nav__cta:hover {
    border-color: var(--fuse-cyan);
    color: var(--fuse-cyan);
  }

  @media (max-width: 820px) {
    .nav__links {
      display: none;
    }
    .nav__wrap {
      grid-template-columns: 1fr auto;
    }
  }
</style>
